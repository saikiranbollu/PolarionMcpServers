# ============================================================
# .env.example — Polarion MCP Server Environment Variables
# ============================================================
# Copy this file to .env (gitignored) and fill in real values.
# The server reads these at startup and overrides the values
# in appsettings.json (or appsettings.Development.json).
#
# NEVER commit .env with real credentials.
# The .env file is listed in .gitignore by default.
#
# Priority for Polarion credentials (highest → lowest):
#   1. POLARION_{ALIAS}_PAT     — PAT for a named project alias
#   2. POLARION_PAT             — PAT for the default project
#   3. POLARION_{ALIAS}_PASSWORD — password for a named alias
#   4. POLARION_PASSWORD        — password for the default project
#   5. appsettings.json values
#
# Alias normalization: project alias is uppercased and all
# non-alphanumeric characters replaced with _.
#   "my-project" → "MY_PROJECT"
#   "starlight"  → "STARLIGHT"
# ============================================================

# Default Polarion project alias (must match a ProjectUrlAlias in appsettings.json)
# If not set, uses the project marked Default=true in appsettings, or first project
POLARION_DEFAULT_PROJECT=myproject

# ---------------------------------------------------------------
# PERSONAL ACCESS TOKENS (PAT)  — Recommended over passwords
# ---------------------------------------------------------------
# Generate PATs from Polarion: My Account → Personal Access Tokens
# A PAT is a long-lived token that does not change when you reset
# your password. Revoke tokens individually when compromised.

# PAT for a named project alias
# POLARION_STARLIGHT_PAT=
# POLARION_OCTOPUS_PAT=

# PAT applied to the project marked Default=true in appsettings.json
# (used when no alias-specific PAT is found)
POLARION_PAT=

# ---------------------------------------------------------------
# PASSWORDS (legacy, prefer PAT above)
# ---------------------------------------------------------------
# POLARION_STARLIGHT_PASSWORD=
# POLARION_OCTOPUS_PASSWORD=
POLARION_PASSWORD=

# ---------------------------------------------------------------
# MCP SERVER API KEYS (for ApiConsumers authentication)
# ---------------------------------------------------------------
# These are the keys MCP clients / AI agents send in X-API-Key.
# Set them here and reference them in appsettings.json as
# ApplicationKey values, OR hard-code them directly in
# appsettings.Development.json (which is gitignored).
MCP_READ_API_KEY=
MCP_WRITE_API_KEY=

# ---------------------------------------------------------------
# SERVER SETTINGS
# ---------------------------------------------------------------
# Uncomment to override the default port (5090 for dev).
# ASPNETCORE_URLS=http://+:8080

# Uncomment to set ASP.NET Core environment.
# ASPNETCORE_ENVIRONMENT=Production
